# ================================================================
# NEXUS Backend — Environment Variables
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to git.
# ================================================================

APP_NAME="NEXUS Human-AI Co-Evolution Engine"
ENVIRONMENT=development

# ---------------------------------------------------------------
# Azure OpenAI (Azure AI Foundry)
# Used by: OpenAIService, SignalFuserAgent, GapAnalyserAgent
# ---------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ---------------------------------------------------------------
# Azure AI Search  (Semantic Kernel Memory Store)
# Used by: memory.py / Semantic Kernel kernel
# ---------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=<your-search-admin-key>
AZURE_SEARCH_INDEX=nexus-capabilities

# ---------------------------------------------------------------
# Azure Cosmos DB
# Used by: CapabilityModelDoc, AgentActionDoc persistence
# ---------------------------------------------------------------
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-key>
COSMOS_DB=nexus

# ---------------------------------------------------------------
# Azure SignalR Service
# Used by: SignalRService — real-time push to Next.js frontend
# ---------------------------------------------------------------
SIGNALR_CONNECTION_STRING=Endpoint=https://<your-signalr>.service.signalr.net;AccessKey=<key>;Version=1.0;

# ---------------------------------------------------------------
# Anthropic Claude  (Capability Modeller)
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=<your-anthropic-key>
CLAUDE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------
# Google Gemini  (Action Planner)
# ---------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-key>
GEMINI_MODEL=gemini-1.5-pro

# ---------------------------------------------------------------
# Microsoft Graph API  (M365 Calendar + Teams + Docs metadata)
# ---------------------------------------------------------------
MS_GRAPH_TENANT_ID=<your-aad-tenant-id>
MS_GRAPH_CLIENT_ID=<your-app-registration-client-id>
MS_GRAPH_CLIENT_SECRET=<your-client-secret>

# ---------------------------------------------------------------
# CORS
# ---------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","https://<your-production-domain>"]
