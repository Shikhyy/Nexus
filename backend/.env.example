# ==========================================
# NEXUS - Environment Configuration Guide
# ==========================================
# Rename this file to .env and fill in the values.

# ------------------------------------------
# 1. Groq (Fast LLM Inference)
# ------------------------------------------
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ------------------------------------------
# 2. Azure OpenAI (Alternative LLM)
# ------------------------------------------
# Get from: Azure Portal -> Azure OpenAI Service -> Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ------------------------------------------
# 3. Azure AI Search (Semantic Memory)
# ------------------------------------------
# Get from: Azure Portal -> Azure AI Search -> Keys
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_key_here
AZURE_SEARCH_INDEX=nexus-capabilities

# ------------------------------------------
# 4. Azure Cosmos DB (NoSQL Data)
# ------------------------------------------
# Get from: Azure Portal -> Azure Cosmos DB -> Keys
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key_here
COSMOS_DB=nexus

# ------------------------------------------
# 5. Azure SignalR (Real-time Sockets)
# ------------------------------------------
# Get from: Azure Portal -> Azure Web PubSub / SignalR -> Keys
SIGNALR_CONNECTION_STRING=Endpoint=https://your-signalr.service.signalr.net;AccessKey=...;Version=1.0;

# ------------------------------------------
# 6. Google Gemini (Alternative Action Planner)
# ------------------------------------------
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ------------------------------------------
# 7. Anthropic (Alternative Capability Modeller)
# ------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ------------------------------------------
# 8. Microsoft Graph API (M365 Integration)
# ------------------------------------------
# Get from: Azure Portal -> Microsoft Entra ID -> App Registrations -> Your App -> Certificates & secrets
MS_GRAPH_TENANT_ID=your_tenant_id_here
MS_GRAPH_CLIENT_ID=your_client_id_here
MS_GRAPH_CLIENT_SECRET=your_client_secret_here

# ------------------------------------------
# 9. Local Configuration
# ------------------------------------------
APP_NAME="NEXUS Human-AI Co-Evolution Engine"
ENVIRONMENT=development
